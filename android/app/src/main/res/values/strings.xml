    <string name="settings_gpu_fps_hack_desc">Game hack. May double the framerate from 30 FPS to 60 FPS in some games,\nbut can cause some games to run twice as fast.</string>
    <string name="settings_gpu_turbo_mode">Turbo Mode</string>
    <string name="settings_gpu_turbo_mode_desc">Provides a way to force the GPU to run at the maximum possible clocks. Thermal constraints will still be applied.</string>
    <string name="settings_gpu_shader_cache">Enable Shader Cache</string>
    <string name="settings_gpu_shader_cache_desc">Enable shader caching. Reduces stuttering on subsequent runs.</string>
